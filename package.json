{
  "name": "mercari-scraper",
  "private": true,
  "author": "kevinxo328",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "generate": "turbo run generate",
    "type-check": "turbo run type-check",
    "check": "oxlint . --deny-warnings && turbo run type-check",
    "lint": "oxlint . --deny-warnings",
    "test": "turbo run test",
    "lint:fix": "oxlint . --fix"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-turbo": "^2.9.6",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsx": "4.19.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "next": "^16.2.3",
      "esbuild": "^0.25.0",
      "srvx": "^0.11.13",
      "@hono/node-server": "^1.19.13",
      "postcss": "^8.5.10",
      "defu": "^6.1.5",
      "picomatch": "^4.0.4",
      "drizzle-orm": "^0.45.2",
      "h3": "^2.0.1-rc.18"
    }
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.9.0"
