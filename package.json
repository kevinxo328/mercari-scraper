      "glob": ">=10.5.0",
      "minimatch": ">=3.1.3",
      "rollup": ">=4.59.0",
      "vite": "npm:rolldown-vite@7.3.1",
      "vitest>vite": "npm:rolldown-vite@7.3.1"
