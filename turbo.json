{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "generate",
        "test"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".output/**"
      ],
      "env": [
        "NODE_ENV",
        "AUTH_ALLOW_EMAILS",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "SLACK_WEBHOOK_URL",
        "WEB_APP_URL",
        "VERCEL_URL"
      ]
    },
    "dev": {
      "dependsOn": [
        "^generate"
      ],
      "cache": false,
      "persistent": true
    },
    "generate": {
      "cache": false
    },
    "type-check": {
      "dependsOn": [
        "^generate"
      ],
      "cache": true
    },
    "lint": {
      "dependsOn": [
        "^generate"
      ]
    },
    "lint:fix": {
      "dependsOn": [
        "^generate"
      ],
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^generate"
      ]
    }
  }
}
