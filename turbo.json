{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".output/**"],
      "env": [
        "NODE_ENV",
        "AUTH_ALLOW_EMAILS",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "SLACK_WEBHOOK_URL",
        "WEB_APP_URL",
        "VERCEL_URL"
      ]
    },
    "dev": {
      "dependsOn": ["^generate"],
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"],
      "cache": false
    },
    "lint": {},
    "lint:fix": { "cache": false },
    "test": {}
  }
}
