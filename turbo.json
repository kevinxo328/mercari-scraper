{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "^generate"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".outputs/**"
      ],
      "env": [
        "NODE_ENV",
        "AUTH_ALLOW_EMAILS",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "SLACK_WEBHOOK_URL",
        "WEB_APP_URL",
        "VERCEL_URL"
      ]
    },
    "db:migrate:dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "dev": {
      "dependsOn": [
        "^generate"
      ],
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": [
        "^generate"
      ],
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "scraper": {
      "cache": false,
      "env": [
        "GITHUB_STEP_SUMMARY",
        "SCRAPE_CONCURRENCY"
      ]
    },
    "scraper:debug": {
      "cache": false
    },
    "scraper:ui": {
      "cache": false
    },
    "scraper:report": {
      "cache": false
    }
  }
}
