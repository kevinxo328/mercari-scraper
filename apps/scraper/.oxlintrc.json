{
  "extends": ["../../.oxlintrc.json"],
  "rules": {
    "turbo/no-undeclared-env-vars": [
      "error",
      {
        "allowList": [
          "NODE_ENV",
          "CI",
          "ANTHROPIC_API_KEY",
          "GITHUB_STEP_SUMMARY",
