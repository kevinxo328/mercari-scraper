{
  "extends": "@mercari-scraper/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    // TODO: Temporarily disable declaration files until we figure out a solution for Next.js
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "types": ["vitest/globals"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
